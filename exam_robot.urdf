<?xml version="1.0"?>
<robot name="my_robot">

  <!-- ==================== BASE_LINK (корпус) ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="blue">
        <color rgba="0 0 1 1"/>  <!-- синий -->
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ==================== LEFT WHEEL (левое колесо) ==================== -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.08"/>
      </geometry>
      <!-- Поворот на 90° вокруг Y, чтобы цилиндр стал вертикальным -->
      <origin rpy="0 ${pi/2} 0" xyz="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>  <!-- черный -->
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- ==================== RIGHT WHEEL (правое колесо) ==================== -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.08"/>
      </geometry>
      <!-- Поворот на 90° вокруг Y, чтобы цилиндр стал вертикальным -->
      <origin rpy="0 ${pi/2} 0" xyz="0 0 0"/>
      <material name="black">
        <color rgba="0 0 0 1"/>  <!-- черный -->
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- ==================== SENSOR_LINK (датчик расстояния) ==================== -->
  <link name="sensor_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <material name="red">
        <color rgba="1 0 0 1"/>  <!-- красный -->
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ==================== СУСТАВЫ ==================== -->

  <!-- ЛЕВОЕ КОЛЕСО: continuous сустав -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin rpy="0 0 0" xyz="0 0.17 0"/>  <!-- смещение по Y влево -->
    <axis xyz="0 0 1"/>  <!-- вращение вокруг оси Z -->
  </joint>

  <!-- ПРАВОЕ КОЛЕСО: continuous сустав -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin rpy="0 0 0" xyz="0 -0.17 0"/>  <!-- смещение по Y вправо -->
    <axis xyz="0 0 1"/>  <!-- вращение вокруг оси Z -->
  </joint>

  <!-- ДАТЧИК: fixed сустав -->
  <joint name="sensor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_link"/>
    <origin rpy="0 0 0" xyz="0.2 0 0.08"/>  <!-- спереди и сверху -->
  </joint>

</robot>
